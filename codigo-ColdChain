const char* password = "0208123840";
const char* mqtt_server = "9ace28d159244a72b5cbf0a08e02c7d7.s1.eu.hivemq.cloud"; // O mesmo que você usou no Node-RED
const char* mqtt_user = "hivemq.webclient.1774046277295"; // OBRIGATÓRIO no HiveMQ Cloud
